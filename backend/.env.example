# Neon Postgres connection string (from https://console.neon.tech -> your project -> Connect)
# Use the pooled connection string; keep the ?sslmode=require suffix.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Chat provider: NVIDIA Build API first, Gemini as automatic fallback.
# Set LLM_FALLBACK_PROVIDER empty to disable falling back.
LLM_PROVIDER=nvidia
LLM_FALLBACK_PROVIDER=gemini

# NVIDIA Build API key (https://build.nvidia.com -> Get API Key)
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_CHAT_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA's free tier can queue requests for minutes; past this window the app
# treats it as unavailable and uses the fallback provider.
NVIDIA_TIMEOUT_SECONDS=45

# Google AI Studio API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-3.5-flash
# Used when the main Gemini model stays overloaded (503) after retries; empty disables.
GEMINI_FALLBACK_MODEL=gemini-flash-lite-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# NOTE: Voyage voyage-3.5 only supports 256/512/1024/2048; Gemini supports up to 3072.
# Changing this after diaries exist requires re-embedding (ALTER TABLE ... TYPE vector(N)).
EMBEDDING_DIMENSIONS=1024
CORS_ORIGINS=http://localhost:3000

# Google Sign-In (create an OAuth Client ID at https://console.cloud.google.com/apis/credentials,
# type "Web application", authorized JavaScript origin http://localhost:3000).
# Leave GOOGLE_CLIENT_ID empty to run without login (single-user mode).
GOOGLE_CLIENT_ID=
AUTH_SECRET=generate-a-long-random-string
AUTH_TOKEN_DAYS=30

# Optional: use Voyage AI for embeddings instead of the chat provider
# EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=your-voyage-api-key
# VOYAGE_EMBEDDING_MODEL=voyage-3.5

# Memory system (defaults shown). Diary entries / extracted memories below these
# importance thresholds are stored but not embedded; temporary memories expire.
# DIARY_EMBED_MIN_IMPORTANCE=0.35
# MEMORY_EMBED_MIN_IMPORTANCE=0.55
# TEMPORARY_MEMORY_DAYS=30

# Cloudinary chat file uploads (https://console.cloudinary.com -> Dashboard).
# Leave empty to disable uploads. Files are purged after ATTACHMENT_TTL_DAYS.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# ATTACHMENT_TTL_DAYS=7
# MAX_UPLOAD_MB=10
